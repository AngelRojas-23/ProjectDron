# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/streaming_dron"
POSTGRES_PASSWORD=postgres

# Authentication — REQUIRED: generate with: openssl rand -hex 32
JWT_SECRET="your-secret-key-here-change-in-production"

# Server Ports
BACKEND_PORT=3000
STREAMING_PORT=3001
FRONTEND_PORT=5173

# MAVLink Bridge
MAVLINK_WS_URL=ws://localhost:8088/v1/ws/mavlink
MAVLINK_REST_URL=http://localhost:8088/v1/mavlink

# pgAdmin (development only — not started in production)
PGADMIN_EMAIL=admin@streaming-dron.local
PGADMIN_PASSWORD=admin